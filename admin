<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>OWNER DASHBOARD - MANAGE ORDERS</title>
    <style>
        body { font-family: 'Poppins', sans-serif; background: #111; color: #fff; padding: 20px; }
        .order-card { background: #222; border: 1px solid #f1c40f; padding: 15px; margin-bottom: 20px; border-radius: 10px; }
        .btn-approve { background: #2ecc71; color: white; border: none; padding: 10px; border-radius: 5px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 10px; }
        .btn-reject { background: #e74c3c; color: white; margin-top: 5px; }
        input { width: 100%; padding: 10px; margin-top: 10px; border-radius: 5px; border: 1px solid #444; background: #000; color: #fff; box-sizing: border-box; }
        .status { font-weight: bold; color: #f1c40f; margin-bottom: 10px; }
    </style>
</head>
<body>
    <h2>RESTAURANT ADMIN - LIVE ORDERS</h2>
    <div id="orders-list">Loading orders from Google Sheet...</div>

<script>
    const SHEET_CSV = 'https://docs.google.com/spreadsheets/d/1Mb0nfkDRt19dGJ37MgfyMmoLk9UCr_7TkcLywSsmffI/gviz/tq?tqx=out:csv';

    async function loadAdminOrders() {
        const res = await fetch(SHEET_CSV);
        const data = await res.text();
        const rows = data.split('\n').slice(1);
        let html = '';
        rows.forEach((row, i) => {
            const cols = row.split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
            if(cols[1]) {
                const name = cols[1].replace(/"/g, '');
                const phone = cols[5].replace(/"/g, '');
                const items = cols[2].replace(/"/g, '');
                const total = cols[3].replace(/"/g, '');
                const addr = cols[4].replace(/"/g, '');
                const txn = cols[6].replace(/"/g, '');

                html += `<div class="order-card">
                    <div class="status">NEW ORDER #${i+1}</div>
                    <b>Customer:</b> ${name} (${phone})<br>
                    <b>Items:</b> ${items}<br>
                    <b>Amount:</b> ₹${total} | <b>TXN:</b> ${txn}<br>
                    <b>Address:</b> ${addr}<br>
                    <input type="text" id="boy-${i}" placeholder="Delivery Boy Name & Number">
                    <button class="btn-approve" onclick="sendWA('${phone}','${name}','${i}','Approved')">CONFIRM & SEND WHATSAPP</button>
                    <button class="btn-approve btn-reject" onclick="sendWA('${phone}','${name}','${i}','Rejected')">REJECT ORDER</button>
                </div>`;
            }
        });
        document.getElementById('orders-list').innerHTML = html || "No orders found.";
    }

    function sendWA(phone, name, i, status) {
        const boy = document.getElementById('boy-'+i).value;
        let msg = "";
        if(status === 'Approved') {
            msg = `*ORDER CONFIRMED!* ✅%0AHi ${name}, your order is accepted.%0A🛵 *Delivery Boy:* ${boy}%0APlease be ready!`;
        } else {
            msg = `*ORDER REJECTED* ❌%0AHi ${name}, sorry we cannot deliver your order right now.`;
        }
        window.open(`https://wa.me/91${phone}?text=${msg}`);
    }
    loadAdminOrders();
</script>
</body>
</html>
